# ═══════════════════════════════════════════════════════════════════════════════
#  PariMarket — Environment Variables
#  Copy this file:  cp .env.sample .env
#  Then fill in every value before running agents or deploying.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Google AI ──────────────────────────────────────────────────────────────────
# Required. Get your key at https://aistudio.google.com/app/apikey
# Free tier works fine for development.
GOOGLE_API_KEY=AIza...

# Gemini model to use. gemini-2.0-flash is fast and cheap.
GEMINI_MODEL=gemini-2.5-flash


# ── Etherlink Shadownet ────────────────────────────────────────────────────────
# RPC endpoint for Etherlink Shadownet (testnet)
BASE_RPC_URL=https://node.shadownet.etherlink.com

# Chain ID: 127823 = Etherlink Shadownet
BASE_CHAIN_ID=127823


# ── Deployed Contract ──────────────────────────────────────────────────────────
# Filled in automatically by scripts/deploy.py after deployment.
# Also paste this value into frontend/index.html → CFG.CONTRACT
CONTRACT_ADDRESS=0x...


# ── Agent Wallet Private Keys ──────────────────────────────────────────────────
# SECURITY: Never commit this file to git. Keep it out of version control.
#
# Each agent role needs its own wallet funded with XTZ for gas.
# On Etherlink Shadownet, get free XTZ from: https://faucet.etherlink.com
#
# For local testing you can use the SAME private key for all roles,
# but in production use separate wallets for each role.
#
# Format: 0x followed by 64 hex characters

# Owner wallet — creates markets, cancels, withdraws commission
OWNER_PRIVATE_KEY=0x...

# Oracle wallet — posts CoinGecko prices on-chain to resolve markets
ORACLE_PRIVATE_KEY=0x...

# Timer wallet — opens and closes betting windows
TIMER_PRIVATE_KEY=0x...

# Distribution wallet — triggers batch USDC payouts to winners
DISTRIBUTION_PRIVATE_KEY=0x...


# ── Agent Wallet Addresses ─────────────────────────────────────────────────────
# Derived from the private keys above — used as constructor arguments in deploy.py
# You can compute these with: python scripts/show_addresses.py
ORACLE_ADDRESS=0x...
TIMER_ADDRESS=0x...
DISTRIBUTION_ADDRESS=0x...


# ── CoinGecko API ──────────────────────────────────────────────────────────────
# Optional. Leave empty to use the free public API (rate-limited to ~30 req/min).
# Get a Pro key at https://www.coingecko.com/en/api/pricing for higher limits.
COINGECKO_API_KEY=


# ── Market Parameters ──────────────────────────────────────────────────────────
# How many hours before resolution to stop accepting bets (default: 2)
CLOSE_BEFORE_RESOLUTION_HOURS=2

# UTC hour at which daily markets resolve (default: 0 = midnight UTC)
RESOLUTION_HOUR_UTC=0


# ── Scheduler ──────────────────────────────────────────────────────────────────
# How often the root orchestrator ticks, in seconds (default: 300 = 5 minutes)
TICKER_INTERVAL_SECS=3600
